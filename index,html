<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Aununj — Ruang Belajar</title>
<meta name="description" content="Kumpulan link pembelajaran coding &amp; IPAS untuk siswa, dikurasi oleh Aununj." />

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">

<style>
  :root{
    --bg-deep:#160A2B;
    --bg-deep-2:#1F0F3D;
    --purple:#7C3AED;
    --purple-light:#A78BFA;
    --green:#10B981;
    --lime:#A3E635;
    --ink:#F5F3FF;
    --muted:#B4A8D6;
    --card-bg:rgba(255,255,255,0.05);
    --card-border:rgba(255,255,255,0.09);
    --radius:16px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--bg-deep);
    color:var(--ink);
    font-family:'Plus Jakarta Sans', sans-serif;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  #root{position:relative; min-height:100vh;}

  .display{font-family:'Space Grotesk', sans-serif;}
  .mono{font-family:'JetBrains Mono', monospace;}

  /* ---------- AURORA / SIGNATURE BACKGROUND ---------- */
  .aurora{
    position:fixed; inset:0; z-index:0; pointer-events:none;
    background:
      radial-gradient(600px 400px at 15% 10%, rgba(124,58,237,0.35), transparent 60%),
      radial-gradient(700px 500px at 85% 15%, rgba(16,185,129,0.28), transparent 60%),
      radial-gradient(500px 400px at 50% 90%, rgba(163,230,53,0.10), transparent 60%);
    filter:blur(10px);
    animation:driftAurora 22s ease-in-out infinite alternate;
  }
  @keyframes driftAurora{
    0%{ transform:translate(0,0) scale(1); }
    100%{ transform:translate(-2%, 3%) scale(1.05); }
  }
  .noise-grid{
    position:fixed; inset:0; z-index:0; pointer-events:none; opacity:0.5;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size:42px 42px;
    mask-image:radial-gradient(ellipse 80% 60% at 50% 0%, black 40%, transparent 90%);
  }

  .wrap{position:relative; z-index:1; max-width:1080px; margin:0 auto; padding:0 24px;}

  /* ---------- HERO ---------- */
  .hero{padding:88px 0 56px; text-align:center;}
  .badge{
    display:inline-flex; align-items:center; gap:8px;
    font-family:'JetBrains Mono', monospace; font-size:12.5px; letter-spacing:.04em;
    color:var(--lime); background:rgba(163,230,53,0.08);
    border:1px solid rgba(163,230,53,0.25); padding:6px 14px; border-radius:999px;
    margin-bottom:28px;
  }
  .badge .dot{width:6px; height:6px; border-radius:50%; background:var(--lime); box-shadow:0 0 8px var(--lime);}
  .hero h1{
    font-size:clamp(48px, 9vw, 88px); font-weight:700; margin:0 0 18px;
    letter-spacing:-0.03em; line-height:0.95;
    background:linear-gradient(120deg, #C4B5FD 0%, #F5F3FF 30%, #6EE7B7 75%, #A3E635 100%);
    -webkit-background-clip:text; background-clip:text; color:transparent;
  }
  .hero p.lead{
    font-size:clamp(16px,2.4vw,19px); color:var(--muted); max-width:560px; margin:0 auto;
    line-height:1.6;
  }
  .hero .role{
    display:block; margin-top:10px; font-family:'JetBrains Mono', monospace;
    font-size:13px; color:var(--purple-light); letter-spacing:.03em;
  }

  /* ---------- FILTER CHIPS ---------- */
  .chips{
    display:flex; flex-wrap:wrap; gap:10px; justify-content:center;
    margin:40px 0 8px;
  }
  .chip{
    font-family:'JetBrains Mono', monospace; font-size:13px;
    padding:9px 18px; border-radius:999px; cursor:pointer;
    background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.10);
    color:var(--muted); transition:all .2s ease; user-select:none;
  }
  .chip:hover{ border-color:rgba(255,255,255,0.25); color:var(--ink); }
  .chip:focus-visible{ outline:2px solid var(--lime); outline-offset:2px; }
  .chip.active{
    background:linear-gradient(120deg, var(--purple), var(--green));
    border-color:transparent; color:#fff; font-weight:600;
  }

  /* ---------- LINK SECTIONS ---------- */
  main{padding:24px 0 100px;}
  .category-block{margin-top:56px;}
  .category-head{
    display:flex; align-items:baseline; gap:14px; margin-bottom:22px;
  }
  .category-head .num{
    font-family:'JetBrains Mono', monospace; font-size:13px; color:var(--green);
  }
  .category-head h2{
    font-family:'Space Grotesk', sans-serif; font-size:22px; font-weight:600;
    margin:0; letter-spacing:-0.01em;
  }
  .category-head .line{flex:1; height:1px; background:linear-gradient(90deg, rgba(255,255,255,0.16), transparent);}

  .grid{
    display:grid; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr)); gap:16px;
  }

  .card{
    display:flex; flex-direction:column; gap:14px;
    background:var(--card-bg); border:1px solid var(--card-border);
    border-radius:var(--radius); padding:22px;
    text-decoration:none; color:var(--ink);
    position:relative; overflow:hidden;
    transition:transform .22s ease, border-color .22s ease, background .22s ease;
  }
  .card::before{
    content:""; position:absolute; inset:0; opacity:0; transition:opacity .25s ease;
    background:linear-gradient(135deg, rgba(124,58,237,0.16), rgba(16,185,129,0.14));
  }
  .card:hover, .card:focus-visible{
    transform:translateY(-4px);
    border-color:rgba(167,139,250,0.45);
  }
  .card:hover::before, .card:focus-visible::before{opacity:1;}
  .card:focus-visible{outline:2px solid var(--lime); outline-offset:2px;}

  .card-top{display:flex; align-items:center; justify-content:space-between; position:relative; z-index:1;}
  .card-icon{
    width:38px; height:38px; border-radius:10px; display:flex; align-items:center; justify-content:center;
    font-size:18px; font-weight:700; font-family:'Space Grotesk', sans-serif;
    background:linear-gradient(135deg, var(--purple), var(--green)); color:#fff;
    flex-shrink:0;
  }
  .card-arrow{
    color:var(--muted); font-size:16px; transition:transform .22s ease, color .22s ease;
  }
  .card:hover .card-arrow{ transform:translate(3px,-3px); color:var(--lime); }

  .card h3{
    font-family:'Space Grotesk', sans-serif; font-size:17px; font-weight:600;
    margin:0; position:relative; z-index:1; line-height:1.3;
  }
  .card p{
    margin:0; font-size:13.5px; color:var(--muted); line-height:1.5; position:relative; z-index:1;
  }

  .empty{
    text-align:center; padding:60px 20px; color:var(--muted);
    font-family:'JetBrains Mono', monospace; font-size:14px;
  }

  /* ---------- FOOTER ---------- */
  footer{
    position:relative; z-index:1; border-top:1px solid rgba(255,255,255,0.08);
    padding:36px 24px; text-align:center;
  }
  footer p{
    margin:0; font-size:13px; color:var(--muted); font-family:'JetBrains Mono', monospace;
  }
  footer .heart{color:var(--lime);}

  @media (prefers-reduced-motion: reduce){
    .aurora{animation:none;}
    .card, .chip, .card-arrow{transition:none;}
  }

  @media (max-width:560px){
    .hero{padding:64px 0 40px;}
    .grid{grid-template-columns:1fr;}
  }
</style>
</head>
<body>

<div class="aurora"></div>
<div class="noise-grid"></div>
<div id="root"></div>

<!--
  ====================================================================
  DATA LINK — EDIT DI SINI SAJA
  ====================================================================
  Ini satu-satunya bagian yang perlu disentuh untuk menambah,
  mengubah, atau menghapus link pembelajaran. Tidak perlu backend
  atau database — cukup edit array di bawah, simpan, lalu commit &
  push ke GitHub. GitHub Pages akan otomatis memperbarui halaman.

  Setiap item punya field:
    category : nama kategori (link dengan kategori sama akan
                dikelompokkan otomatis)
    title    : judul yang tampil di kartu
    desc     : deskripsi singkat (1 baris cukup)
    url      : alamat tujuan (harus lengkap, diawali https://)
    icon     : 1-2 karakter/emoji untuk badge ikon kartu

  Contoh menambah link baru: salin satu blok { ... }, tempel sebelum
  tanda kurung siku penutup "]", lalu ganti isinya.
  ====================================================================
-->
<script>
  window.AUNUNJ_LINKS = [
    { category: "Coding", title: "Scratch", desc: "Belajar logika pemrograman dengan blok visual.", url: "https://scratch.mit.edu", icon: "S" },
    { category: "Coding", title: "Code.org", desc: "Kursus coding interaktif untuk pemula.", url: "https://code.org", icon: "C" },
    { category: "Coding", title: "Tynker", desc: "Game & proyek coding untuk anak-anak.", url: "https://www.tynker.com", icon: "T" },

    { category: "IPAS", title: "PhET Simulations", desc: "Simulasi interaktif sains & IPA.", url: "https://phet.colorado.edu", icon: "P" },
    { category: "IPAS", title: "NASA Kids' Club", desc: "Jelajah luar angkasa untuk siswa.", url: "https://www.nasa.gov/kidsclub", icon: "N" },

    { category: "Belajar Umum", title: "Rumah Belajar Kemdikbud", desc: "Portal belajar resmi Kemdikbudristek.", url: "https://belajar.kemdikbud.go.id", icon: "R" },
    { category: "Belajar Umum", title: "Khan Academy", desc: "Materi lengkap dari dasar sampai lanjutan.", url: "https://www.khanacademy.org", icon: "K" }
  ];
</script>

<script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js" crossorigin></script>

<script type="text/babel" data-presets="react">
const { useState, useMemo } = React;

function groupByCategory(links) {
  const map = new Map();
  links.forEach(link => {
    if (!map.has(link.category)) map.set(link.category, []);
    map.get(link.category).push(link);
  });
  return map;
}

function LinkCard({ link }) {
  return (
    <a className="card" href={link.url} target="_blank" rel="noopener noreferrer">
      <div className="card-top">
        <div className="card-icon">{link.icon || link.title.charAt(0)}</div>
        <span className="card-arrow">↗</span>
      </div>
      <h3>{link.title}</h3>
      <p>{link.desc}</p>
    </a>
  );
}

function App() {
  const links = window.AUNUNJ_LINKS || [];
  const categories = useMemo(() => ["Semua", ...Array.from(new Set(links.map(l => l.category)))], [links]);
  const [active, setActive] = useState("Semua");

  const filtered = active === "Semua" ? links : links.filter(l => l.category === active);
  const grouped = groupByCategory(filtered);

  return (
    <React.Fragment>
      <div className="wrap">
        <section className="hero">
          <span className="badge"><span className="dot"></span>RUANG BELAJAR AKTIF</span>
          <h1 className="display">Aununj</h1>
          <p className="lead">
            Kumpulan link pembelajaran pilihan — coding, IPAS, dan sumber
            belajar lain — disusun rapi supaya kamu tinggal klik dan mulai.
            <span className="role">dikurasi oleh seorang guru</span>
          </p>

          <nav className="chips" aria-label="Filter kategori">
            {categories.map(cat => (
              <button
                key={cat}
                className={"chip" + (active === cat ? " active" : "")}
                onClick={() => setActive(cat)}
              >
                {cat}
              </button>
            ))}
          </nav>
        </section>

        <main>
          {grouped.size === 0 && (
            <p className="empty">Belum ada link di kategori ini.</p>
          )}
          {Array.from(grouped.entries()).map(([category, items], idx) => (
            <div className="category-block" key={category}>
              <div className="category-head">
                <span className="num mono">{String(idx + 1).padStart(2, "0")}</span>
                <h2 className="display">{category}</h2>
                <div className="line"></div>
              </div>
              <div className="grid">
                {items.map((link, i) => (
                  <LinkCard link={link} key={link.url + i} />
                ))}
              </div>
            </div>
          ))}
        </main>
      </div>

      <footer>
        <p>dibuat dengan <span className="heart">♥</span> oleh Aununj — {new Date().getFullYear()}</p>
      </footer>
    </React.Fragment>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>

</body>
</html>
